<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBF9F8">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="#FFFFFF"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="#1B1C1C"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="@string/edit_title"
            android:textColor="#1B1C1C"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

    </androidx.appcompat.widget.Toolbar>

    <View
        android:id="@+id/toolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E4E2E1"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <ScrollView
        android:id="@+id/editScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomActionContainer"
        app:layout_constraintTop_toBottomOf="@id/toolbarDivider">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivRestaurantImage"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                tools:src="@tools:sample/backgrounds/scenic"
                android:contentDescription="@string/app_name"
                app:shapeAppearanceOverlay="@style/RoundedCornersImage"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Restaurant Name -->
            <TextView
                android:id="@+id/tvNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/name_label"
                android:textColor="#404752"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivRestaurantImage" />

            <EditText
                android:id="@+id/etRestaurantName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/name_hint"
                android:inputType="text"
                android:padding="12dp"
                android:drawableStart="@drawable/ic_restaurant"
                android:drawablePadding="12dp"
                android:drawableTint="#707883"
                android:background="@drawable/edit_text_background"
                android:textColor="#1B1C1C"
                android:textSize="16sp"
                android:importantForAutofill="no"
                app:layout_constraintTop_toBottomOf="@id/tvNameLabel" />

            <!-- Category -->
            <TextView
                android:id="@+id/tvCategoryLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/category_label"
                android:textColor="#404752"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etRestaurantName" />

            <FrameLayout
                android:id="@+id/spinnerContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background"
                app:layout_constraintTop_toBottomOf="@id/tvCategoryLabel">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_cafe"
                    android:contentDescription="@null"
                    app:tint="#707883" />

                <Spinner
                    android:id="@+id/categorySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="40dp"
                    android:padding="12dp"
                    android:spinnerMode="dropdown"
                    android:overlapAnchor="false"
                    android:background="@android:color/transparent" />
            </FrameLayout>

            <!-- Rating -->
            <TextView
                android:id="@+id/tvRatingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/rating_label"
                android:textColor="#404752"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/spinnerContainer" />

            <EditText
                android:id="@+id/etRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/rating_hint"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:drawableStart="@drawable/ic_star"
                android:drawablePadding="12dp"
                android:drawableTint="#707883"
                android:background="@drawable/edit_text_background"
                android:textColor="#1B1C1C"
                android:textSize="16sp"
                android:importantForAutofill="no"
                app:layout_constraintTop_toBottomOf="@id/tvRatingLabel" />

            <!-- Delivery Time -->
            <TextView
                android:id="@+id/tvDeliveryTimeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/delivery_time_label"
                android:textColor="#404752"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etRating" />

            <EditText
                android:id="@+id/etDeliveryTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/delivery_time_hint"
                android:inputType="text"
                android:padding="12dp"
                android:drawableStart="@drawable/ic_schedule"
                android:drawablePadding="12dp"
                android:drawableTint="#707883"
                android:background="@drawable/edit_text_background"
                android:textColor="#1B1C1C"
                android:textSize="16sp"
                android:importantForAutofill="no"
                app:layout_constraintTop_toBottomOf="@id/tvDeliveryTimeLabel" />

            <!-- Address -->
            <TextView
                android:id="@+id/tvAddressLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/address_label"
                android:textColor="#404752"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etDeliveryTime" />

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/address_hint"
                android:inputType="textPostalAddress"
                android:padding="12dp"
                android:drawableStart="@drawable/ic_location"
                android:drawablePadding="12dp"
                android:drawableTint="#707883"
                android:background="@drawable/edit_text_background"
                android:textColor="#1B1C1C"
                android:textSize="16sp"
                android:importantForAutofill="no"
                app:layout_constraintTop_toBottomOf="@id/tvAddressLabel" />

            <!-- Description -->
            <TextView
                android:id="@+id/tvDescriptionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/description_label"
                android:textColor="#404752"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etAddress" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/description_hint"
                android:inputType="textMultiLine"
                android:minLines="4"
                android:gravity="top"
                android:padding="12dp"
                android:background="@drawable/edit_text_background"
                android:textColor="#1B1C1C"
                android:textSize="16sp"
                android:importantForAutofill="no"
                app:layout_constraintTop_toBottomOf="@id/tvDescriptionLabel" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/bottomActionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#0061A4"
            android:text="@string/save"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_save"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="#FFFFFF" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>